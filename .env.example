# =============================================================================
# Vecto — Environment Configuration Example
# Copy this file to .env and fill in real values before running the project.
# Never commit your actual .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Core Django
# -----------------------------------------------------------------------------

# Long, random secret used for cryptographic signing (sessions, CSRF tokens, etc.)
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to True during local development only. Must be False in production.
DEBUG=False

# ALLOWED_HOSTS is intentionally not env-configurable -- Vecto is
# multi-tenant on arbitrary customer domains, so pod_manager.middleware.
# NetworkMiddleware is the real host gate (see config/settings.py). Only set
# this if you need a genuinely cross-origin CSRF trusted origin (rare):
# CSRF_TRUSTED_ORIGINS=https://admin.yourdomain.com

# -----------------------------------------------------------------------------
# Traefik / Deployment
# -----------------------------------------------------------------------------

# The public domain name the app is served from (used by Traefik for routing
# and TLS certificate generation via Let's Encrypt).
DOMAIN=app.yourdomain.com

# Email address Let's Encrypt will use for certificate expiry notifications.
ACME_EMAIL=admin@yourdomain.com

# Used to setup HTTP Provider in Traefik and provide domains for SSL generation.
TRAEFIK_API_TOKEN=securepassword

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# Name of the PostgreSQL database.
POSTGRES_DB=vecto

# PostgreSQL user with access to the database above.
POSTGRES_USER=vecto_user

# Password for the PostgreSQL user.
POSTGRES_PASSWORD=change-me-to-a-secure-password

# Hostname of the database server. With connection pooling enabled, this should 
# point to the PgBouncer container ("pgbouncer") instead of the raw DB.
POSTGRES_HOST=pgbouncer

# Port the database server is listening on. Default for PgBouncer is 6432 
# (Raw Postgres uses 5432).
POSTGRES_PORT=6432


# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------

# Full Redis connection URL used by both Django Channels and Celery.
# Format: redis://<host>:<port>/<db-index>
# Use "redis" as the host when running via Docker Compose.
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# Secret key used by django-cryptography to encrypt sensitive fields in the
# database (e.g. Patreon tokens). Must stay consistent — changing it will make
# existing encrypted data unreadable.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DJANGO_CRYPTOGRAPHY_KEY=change-me-to-a-fernet-key


# -----------------------------------------------------------------------------
# Patreon API
# -----------------------------------------------------------------------------

# OAuth2 client ID from your Patreon developer application.
# Create one at: https://www.patreon.com/portal/registration/register-clients
PATREON_CLIENT_ID=

# OAuth2 client secret from your Patreon developer application.
PATREON_CLIENT_SECRET=

# The URL Patreon redirects to after a user authorises your app.
# Must exactly match the redirect URI registered in your Patreon app settings.
PATREON_REDIRECT_URI=https://app.yourdomain.com/patreon/callback/

# Secret used to verify the signature of incoming Patreon webhook payloads.
# Set this in your Patreon webhook settings and copy the value here.
PATREON_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Root log level for the application. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log level specifically for Django's internal framework messages.
# Keeping this at INFO or WARNING avoids excessive noise in production.
DJANGO_LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Whisper ASR / Transcription
# -----------------------------------------------------------------------------

# Hugging Face token for speaker diarization via pyannote.audio.
# Required for the whisper container to separate speakers (SPEAKER_00, SPEAKER_01, etc.).
# Create a free account at https://huggingface.co, accept the pyannote model license
# agreements, then generate a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# URL of the running whisper ASR service (/asr endpoint).
# IDE (Windows, no Docker): point at your Unraid host, e.g. http://192.168.1.x:9000
# DEV (Unraid Docker): same Unraid URL, or http://host.docker.internal:9000 from inside a container
# PROD: whisper is now in the Docker stack — this defaults to http://whisper:9000
WHISPER_URL=http://whisper:9000

# Set to False to disable all transcription queuing without removing code.
# Useful for pausing backfills or testing other parts of the stack.
WHISPER_ENABLED=True

# Whisper model size sent as a query param to the /asr endpoint and stored on the Transcript
# record for auditing. Must match the model loaded in the whisper container (set via ASR_MODEL
# on the container). Options: tiny, base, small, medium, medium.en, large, large-v2, large-v3
WHISPER_MODEL=medium.en

# Default language hint passed to the ASR service. Stored on the Transcript model.
WHISPER_LANGUAGE=en

# HTTP timeout in seconds for calls to the /asr endpoint.
# 5400 = 90 minutes, enough to cover long episodes on slower hardware.
WHISPER_TIMEOUT=5400

# When True, the downloaded subscriber MP3 is kept at:
#   MEDIA_ROOT/source_audio/{network_slug}/{podcast_slug}/{original_filename}
# Set True in DEV to build a local audio backup. Always False in PROD.
WHISPER_KEEP_SOURCE_AUDIO=False

# ---------------------------------------------------------------------------
# Cloudflare R2 — subscriber audio mirror
# ---------------------------------------------------------------------------
# Object storage with zero egress, served via a cached custom domain so our
# player gets CORS-clean, seekable bytes (playback speed + transcript sync) and
# we keep an off-platform backup. Subscriber audio ONLY — public/Megaphone is
# never mirrored. Single prod bucket; IDE/dev isolated by R2_KEY_PREFIX.

# Account endpoint: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# R2 API token with Object Read & Write on the bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vecto-audio
# Public custom domain mapped to the bucket (no trailing slash).
R2_PUBLIC_HOST=https://audio.joshtheblack.com
# Prepended to every key. Leave EMPTY in prod; set "dev/" in IDE/dev so dev
# objects are namespaced and bulk-purgeable (manage.py purge_r2_dev).
R2_KEY_PREFIX=
# Master kill-switch for the mirror pipeline (mirrors WHISPER_ENABLED).
R2_MIRROR_ENABLED=True
# Future global "always serve private audio from R2" switch. Keep False until
# the cutover (Phase 6).
R2_FORCE_SERVE=False
# Orphan GC retention windows (days). Reversion/reconciliation orphans may need
# recovery -> long hold; move_rekey orphans are byte-identical -> short hold.
R2_ORPHAN_RETENTION_DAYS=90
R2_REKEY_GRACE_DAYS=7

# ---------------------------------------------------------------------------
# Cloudflare R2 — user-asset CDN (vecto-cdn): uploaded avatars, mix covers,
# transcript files. SEPARATE bucket from the audio mirror, served via
# cdn.joshtheblack.com. Reuses the R2_ENDPOINT / R2_ACCESS_KEY_ID /
# R2_SECRET_ACCESS_KEY above (same account). Stable keys + ?v=N cache-bust, no GC.
# ---------------------------------------------------------------------------
# OPT-IN: must be True before anything writes to the vecto-cdn bucket. Left False
# so an env with the shared R2 creds can't silently write to prod R2.
R2_MEDIA_ENABLED=False
R2_MEDIA_BUCKET=vecto-cdn
# Public host mapped to the bucket (no trailing slash). REQUIRED when
# R2_MEDIA_ENABLED=True — a blank value makes serving raise loudly (a blank host
# would otherwise emit host-relative URLs that loop back to the app and 404).
R2_MEDIA_PUBLIC_HOST=https://cdn.joshtheblack.com
# Prepended to every media key. Leave EMPTY in prod; "dev/" in IDE/dev.
R2_MEDIA_KEY_PREFIX=